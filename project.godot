; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but you can always edit it manually here.
; This is the project configuration associated with the current folder.

config_version=5

[application]

config/name="ArenaForge"
config/description="An auto-battler game inspired by Teamfight Tactics — mobile-first, easy to learn."
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
ShopManager="*res://scripts/autoload/shop_manager.gd"
DataManager="*res://scripts/autoload/data_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/size/mode=0
window/handheld/orientation=1

[rendering]

renderer/rendering_method="forward_plus"

[input_devices]

pointing/emulate_touch_from_mouse=true
